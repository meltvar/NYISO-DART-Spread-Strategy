# Data artifacts (regenerable from gridstatus)
data/raw/

# Processed data — exclude by default; un-exclude the panel files the
# dashboard needs so Streamlit Cloud can serve them without a data pipeline.
data/processed/*
!data/processed/panel.parquet
!data/processed/panel_live_2026.parquet

# Feature matrices — keep predictions_safe.parquet (needed by sandbox page)
# and the build manifest; exclude everything else (large, regenerable).
data/features/*
!data/features/predictions_safe.parquet
!data/features/manifest.json

# Model checkpoints (regenerable from training)
models/checkpoints/

# Results (regenerable from backtest)
results/figures/
results/cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environments
.venv/
.env
.python-version

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
